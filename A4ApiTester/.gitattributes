# 預設所有文字檔自動處理斷行字元
* text=auto

# ========================================
# ClickOnce 專屬設定 (極度重要)
# ========================================
# .deploy 檔案實際上是 DLL/EXE 等二進位檔案加上附檔名，絕對不能被 Git 轉換斷行
*.deploy binary

# ClickOnce 捷徑參考檔
*.appref-ms binary

# ========================================
# 憑證與金鑰 (ClickOnce 簽章用)
# ========================================
*.pfx binary
*.snk binary
*.cer binary

# ========================================
# .NET / C# 標準原始碼設定
# ========================================
*.cs text diff=csharp
*.sln text eol=crlf
*.csproj text merge=union
*.vbproj text merge=union
*.config text
*.resx text
*.xml text
*.json text

# ========================================
# 一般二進位資源檔
# ========================================
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.dll binary
*.exe binary
*.pdb binary